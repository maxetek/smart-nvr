# Database
POSTGRES_USER=smartnvr
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=smartnvr
DATABASE_URL=postgresql+asyncpg://smartnvr:changeme_in_production@postgres:5432/smartnvr

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=changeme_generate_a_random_64_char_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption
ENCRYPTION_KEY=changeme_generate_fernet_key

# go2rtc
GO2RTC_API_URL=http://go2rtc:1984

# Initial Admin
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=changeme_strong_password
INITIAL_ADMIN_EMAIL=admin@smartnvr.local

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# App
APP_NAME=Smart NVR
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO
